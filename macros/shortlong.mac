# This macro just runs one single particle
# to prove that the application works
#
# Run it using "./task macros/1s.mac"
#/DetGeometry/geometry "test"
/run/initialize
/process/had/particle_hp/produce_fission_fragment true
/process/had/particle_hp/use_Wendt_fission_model true
/run/beamOn 227000 # i.e. 2.27e5
